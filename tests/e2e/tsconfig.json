{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node", "@playwright/test"]
  },
  "include": ["**/*.ts", "**/*.mts", "**/*.mjs"],
  "exclude": ["node_modules", "test-results"]
}
